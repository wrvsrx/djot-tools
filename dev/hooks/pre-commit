#!/usr/bin/env bash
#
# Ensure README.md stays in sync with README.dj (generated by this project's own
# exporter). Enable once per clone with:
#
#   git config core.hooksPath dev/hooks
#
set -euo pipefail

# Only run when the README source or output is part of this commit.
if ! git diff --cached --name-only | grep -qE '^README\.(dj|md)$'; then
    exit 0
fi

if ! command -v pandoc >/dev/null 2>&1; then
    echo "pre-commit: pandoc not found; skipping README sync check" >&2
    exit 0
fi

cd "$(git rev-parse --show-toplevel)"

# djot-export depends only on djot-core and lightweight pandoc JSON types, so
# this build is cheap.
cargo build -q -p djot-export

gen() {
    ./target/debug/djot-export README.dj \
        | pandoc -f json -t gfm \
            --lua-filter=dev/title-heading.lua \
            --lua-filter=dev/strip-sections.lua
}

if ! gen | diff - README.md >/dev/null; then
    echo "pre-commit: README.md is out of date with README.dj. Regenerate it:" >&2
    echo "  djot-export README.dj | pandoc -f json -t gfm --lua-filter=dev/title-heading.lua --lua-filter=dev/strip-sections.lua > README.md" >&2
    echo "  git add README.md" >&2
    exit 1
fi
